# =============================================================================
# Chemical Document Parser — Environment Configuration
# =============================================================================
# Copy this file to .env and adjust values for your environment.
#   cp .env.example .env
#
# Priority (highest to lowest): CLI arguments → Environment (.env) → Defaults
# =============================================================================

# ---------------------------------------------------------------------------
# HuggingFace — Model download credentials
# ---------------------------------------------------------------------------
# HuggingFace access token (read-only is sufficient).
# Required to download gated models like MinerU's default VLM.
# Get your token at: https://huggingface.co/settings/tokens
# Alternative: run "huggingface-cli login" once on the machine.
HF_TOKEN=

# ---------------------------------------------------------------------------
# MinerU — PDF parsing engine
# ---------------------------------------------------------------------------
# Backend: pipeline (CPU), hybrid-engine (CPU+VLM), vlm-engine (VLM-only, requires GPU+vLLM)
MINERU_BACKEND=pipeline

# Enable OCR for scanned documents (true/false)
MINERU_ENABLE_OCR=true

# Model source: huggingface or modelscope (use modelscope if HF is inaccessible)
MINERU_MODEL_SOURCE=huggingface

# ---------------------------------------------------------------------------
# MinerU — vLLM Inference (used when MINERU_BACKEND=vlm-engine or hybrid-engine)
# ---------------------------------------------------------------------------

# vLLM engine version: 1=latest (recommended), 0=legacy
VLLM_USE_V1=1

# Device type override. Leave empty to auto-detect.
# Valid values: cuda, ascend, corex, kxpu
MINERU_VLLM_DEVICE=

# Override VRAM size in GB for GPU memory calculation.
# Leave empty to auto-detect from hardware.
MINERU_VIRTUAL_VRAM_SIZE=

# Which GPUs are visible (comma-separated indices). Leave empty for all GPUs.
# Example: 0,1
CUDA_VISIBLE_DEVICES=0

# ---- vLLM Model ----
# Path or HuggingFace model ID for the vision-language model.
# Leave empty to use MinerU's default VLM.
# Example: MinerU2.5-2509-1.2B
MINERU_VLLM_MODEL=

# Number of GPUs for tensor parallelism (default: 1)
MINERU_VLLM_TENSOR_PARALLEL_SIZE=1

# Fraction of GPU memory reserved for the model (0.0–1.0).
# MinerU auto-calculates: ≤8GB VRAM → 0.7, otherwise → 0.5
MINERU_VLLM_GPU_MEMORY_UTILIZATION=

# Maximum context length in tokens (leave empty for model default)
MINERU_VLLM_MAX_MODEL_LEN=

# Data type: auto, float16, or bfloat16
MINERU_VLLM_DTYPE=auto

# Server port for mineru-openai-server mode (default: 30000)
MINERU_VLLM_PORT=

# Trust remote code in the model repository (true/false)
MINERU_VLLM_TRUST_REMOTE_CODE=true

# ---- Remote vLLM / HTTP-client mode ----
# When using -b vlm-http-client or hybrid-http-client, set the endpoint URL
# of the remote mineru-openai-server (or any OpenAI-compatible vLLM endpoint).
# Example: http://10.0.0.5:30000/v1
MINERU_VLLM_ENDPOINT=

# API key for authenticated remote endpoints.
# If the remote vLLM server requires authentication, set the key here.
# It will be passed as the OPENAI_API_KEY environment variable to the subprocess,
# and as --api-key argument to the mineru CLI.
MINERU_VLLM_API_KEY=

# ---------------------------------------------------------------------------
# MolScribe — Chemical structure image → SMILES
# ---------------------------------------------------------------------------

# Confidence threshold for SMILES acceptance (0.0–1.0)
MOLSCRIBE_CONFIDENCE=0.5

# Device for MolScribe inference. Leave empty for auto-detect (cuda if available).
# Options: cpu, cuda, or empty
MOLSCRIBE_DEVICE=

# HuggingFace model repository hosting the MolScribe checkpoint
MOLSCRIBE_MODEL_REPO=yujieq/MolScribe

# Checkpoint filename on HuggingFace
MOLSCRIBE_CHECKPOINT=swin_base_char_aux_1m680k.pth
